{
  "name": "antokel-cloud",
  "version": "1.2.0",
  "description": "Cloud SDK for Antokel engineers. TypeScript/Node.js edition",
  "author": "Antonio Peña Peña <toni@antokel.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/zPy52/antokel-cloud-ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/zPy52/antokel-cloud-ts"
  },
  "keywords": [
    "aws",
    "s3",
    "ec2",
    "dynamodb",
    "antokel",
    "cloud",
    "sdk"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "node --import tsx --test __tests__/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsdown": "^0.21.0-beta.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1001.0",
    "@aws-sdk/client-ec2": "^3.1001.0",
    "@aws-sdk/client-rekognition": "^3.1003.0",
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/credential-providers": "^3.1001.0",
    "@aws-sdk/lib-dynamodb": "^3.1001.0",
    "@smithy/protocol-http": "^5.3.3",
    "zod": ">=3.0.0"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
